{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "_comment": "SPDX-License-Identifier: MPL-2.0",
  "_description": "TextMate grammar for TANGLE — Turing-complete topological programming language",
  "name": "Tangle",
  "scopeName": "source.tangle",
  "fileTypes": [
    "tangle",
    "tgl"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#jtv-blocks"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#invariants"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#generators"
    },
    {
      "include": "#function-definitions"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.hash.tangle",
          "match": "#.*$"
        },
        {
          "name": "comment.block.tangle",
          "begin": "\\(\\*",
          "end": "\\*\\)",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tangle",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tangle",
              "match": "\\\\[nrt\\\\\"0]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.tangle",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.tangle",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.float.tangle",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.tangle",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.tangle",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.identity.tangle",
          "match": "\\bidentity\\b"
        }
      ]
    },
    "jtv-blocks": {
      "patterns": [
        {
          "name": "meta.block.add.tangle",
          "begin": "\\b(add)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "keyword.control.jtv.tangle" },
            "2": { "name": "punctuation.definition.block.begin.tangle" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.definition.block.end.tangle" }
          },
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#constants" },
            { "include": "#identifiers" }
          ]
        },
        {
          "name": "meta.block.harvard.tangle",
          "begin": "\\b(harvard)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "keyword.control.jtv.tangle" },
            "2": { "name": "punctuation.definition.block.begin.tangle" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.definition.block.end.tangle" }
          },
          "patterns": [
            { "include": "#jtv-keywords" },
            { "include": "#jtv-purity" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#constants" },
            { "include": "#identifiers" }
          ]
        }
      ]
    },
    "jtv-keywords": {
      "patterns": [
        {
          "name": "keyword.control.jtv.tangle",
          "match": "\\b(fn|if|else|while|for|return|print|module|import|as|then|reverse)\\b"
        }
      ]
    },
    "jtv-purity": {
      "patterns": [
        {
          "name": "storage.modifier.purity.tangle",
          "match": "@(pure|total)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tangle",
          "match": "\\b(match|with|end|let|in|yield)\\b"
        },
        {
          "name": "keyword.declaration.tangle",
          "match": "\\b(def|weave|into|strands|compute|assert)\\b"
        },
        {
          "name": "keyword.other.topology.tangle",
          "match": "\\b(close|mirror|reverse|simplify|cap|cup|braid)\\b"
        }
      ]
    },
    "invariants": {
      "patterns": [
        {
          "name": "support.function.invariant.tangle",
          "match": "\\b(jones|alexander|homfly|kauffman|writhe|linking)\\b"
        }
      ]
    },
    "generators": {
      "patterns": [
        {
          "name": "variable.other.generator.tangle",
          "match": "\\bs[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.tangle",
          "match": "=>"
        },
        {
          "name": "keyword.operator.pipeline.tangle",
          "match": ">>"
        },
        {
          "name": "keyword.operator.isotopy.tangle",
          "match": "~"
        },
        {
          "name": "keyword.operator.comparison.tangle",
          "match": "=="
        },
        {
          "name": "keyword.operator.assignment.tangle",
          "match": "="
        },
        {
          "name": "keyword.operator.crossing.tangle",
          "match": "[><]"
        },
        {
          "name": "keyword.operator.tensor.tangle",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.compose.tangle",
          "match": "\\."
        },
        {
          "name": "keyword.operator.arithmetic.tangle",
          "match": "\\+|-|\\*|/|\\^"
        }
      ]
    },
    "function-definitions": {
      "patterns": [
        {
          "match": "\\b(def)\\s+([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.tangle"
            },
            "2": {
              "name": "entity.name.function.tangle"
            }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.tangle",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.tangle",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  },
  "_taxonomy": "editors/textmate-grammar"
}
